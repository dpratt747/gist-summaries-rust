{
  "productName": "gist-summary",
  "version": "0.1.0",
  "identifier": "com.gistsummary.app",
  "build": {
    "frontendDist": "../front-end/dist",
    "devUrl": "http://127.0.0.1:5173",
    "beforeDevCommand": "npm --prefix ../front-end run dev",
    "beforeBuildCommand": "npm --prefix ../front-end install && npm --prefix ../front-end run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Gist Summary",
        "width": 1200,
        "height": 700
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "ollama"
    ],
    "resources": [
      "models/**/*"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
